{
    "paymentMethod": "BKT",
    "version": "1.0",
    "uiConfig": {
        "groups": [
            {
                "id": "paymentDetails",
                "title": "Payment Details",
                "panelType": "form",
                "fields": [
                    {
                        "id": "tranRefNo",
                        "label": "Transaction Reference No",
                        "type": "text",
                        "validation": {
                            "required": true
                        },
                        "hooks": {
                            "onBlur": "validateTranRefNo"
                        }
                    },
                    {
                        "id": "valueDate",
                        "label": "Value Date",
                        "type": "date",
                        "validation": {
                            "required": true,
                            "format": "YYYY-MM-DD"
                        },
                        "hooks": {
                            "onChange": "validateValueDate"
                        }
                    },
                    {
                        "id": "paymentDetails",
                        "label": "Payment Details",
                        "type": "textarea",
                        "validation": {
                            "required": true,
                            "maxLength": 200
                        },
                        "hooks": {
                            "onChange": "sanitizePaymentDetails"
                        }
                    }
                ]
            },
            {
                "id": "beneficiaryDetails",
                "title": "Beneficiary Details",
                "panelType": "form",
                "fields": [
                    {
                        "id": "beneficiaryName",
                        "label": "Beneficiary Name",
                        "type": "text",
                        "validation": {
                            "required": true,
                            "maxLength": 100
                        }
                    },
                    {
                        "id": "beneficiaryAccountNo",
                        "label": "Beneficiary Account Number",
                        "type": "text",
                        "validation": {
                            "required": true,
                            "regex": "^[0-9]{10,18}$"
                        },
                        "hooks": {
                            "onBlur": "validateAccountNumber"
                        }
                    },
                    {
                        "id": "beneficiaryAddress1",
                        "label": "Address Line 1",
                        "type": "text",
                        "validation": {
                            "required": true
                        }
                    },
                    {
                        "id": "beneficiaryAddress2",
                        "label": "Address Line 2",
                        "type": "text",
                        "validation": {
                            "required": false
                        }
                    },
                    {
                        "id": "beneficiaryCountry",
                        "label": "Country",
                        "type": "dropdown",
                        "optionsSource": "countryList",
                        "validation": {
                            "required": true
                        }
                    }
                ]
            }
        ]
    },
    "payloadMapping": {
        "tranRefNo": "payment.tranRefNo",
        "valueDate": "payment.valueDate",
        "paymentDetails": "payment.details",
        "beneficiaryName": "beneficiary.name",
        "beneficiaryAccountNo": "beneficiary.accountNo",
        "beneficiaryAddress1": "beneficiary.address.line1",
        "beneficiaryAddress2": "beneficiary.address.line2",
        "beneficiaryCountry": "beneficiary.address.country"
    }
}